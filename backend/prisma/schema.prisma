// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
	id						String 		@id @default(uuid())
	username				String		@unique
	email					String 		@unique
	password_hash			String?
	avatar_url				String?
	is_online				Boolean 	@default(false)
	is_two_factor_enabled	Boolean 	@default(false)
	two_factor_secret		String?
	oauth_provider			String?
	oauth_id 				String?		@unique		
	created_at				DateTime 	@default(now())
	updated_at				DateTime	@updatedAt
	elo_rating				Int 		@default(0)
	ranked_wins				Int 		@default(0)

	matches_participated	Match_Participant[]
	rewards					Daily_Reward[]

	sent_friendships		Friendship[]	@relation("requester")
	received_friendships	Friendship[]	@relation("addressee")

	sent_messages			Message[]		@relation("sent_messages")
	received_messages		Message[]		@relation("received_messages")
}

model Friendship {
	id 						String 		@id @default(uuid())
	status					String 		@default("pending")
	created_at				DateTime	@default(now())

	requester_id			String 	
	requester 				User 		@relation("requester", fields: [requester_id], references: [id])

	addressee_id			String
	addressee    			User     	@relation("addressee", fields: [addressee_id], references: [id])
}

model Message {
	id						String		@id @default(uuid())
	content					String
	created_at				DateTime	@default(now())

	sender_id				String
	sender					User		@relation("sent_messages", fields: [sender_id], references: [id])

	receiver_id				String
	receiver				User		@relation("received_messages", fields: [receiver_id], references: [id])
}

model Match {
	id 						String		@id @default(uuid())
	game_mode				String
	status					String 		@default("ongoing")
	played_at				DateTime	@default(now())

	target_champion_id		String
	target_champion 		Champion 	@relation(fields: [target_champion_id], references: [id])

	participants			Match_Participant[]
	guesses 				Guess[]
}

model Match_Participant {
	id 						String		@id @default(uuid())
	result					String?
	score					Int 		@default(0)

	match_id				String
	match 					Match 		@relation(fields: [match_id], references: [id])
	
	user_id					String
	user 					User 		@relation(fields: [user_id], references: [id])

	guesses 				Guess[]
}

model Guess {
	id 						String 				@id @default(uuid())
	attempt_number			Int
	comparison_result		Json
	is_correct				Boolean				@default(false)

	match_id				String
	match 					Match 				@relation(fields: [match_id], references: [id])

	champion_id				String
	champion 				Champion 			@relation(fields: [champion_id], references: [id])
	
	participant_id 			String
	participant 			Match_Participant 	@relation(fields: [participant_id], references: [id])
}

model Champion {
	id 						String 		@id @default(uuid())
	name					String		@unique
	gender					String
	position				String
	species 				String
	resource_type			String
	range_type				String
	region					String
	release_year			Int

	guesses 				Guess[]
	target_in 				Match[]
	dailychamp				DailyMatch[]
}

model Daily_Reward  {
	id 						String 		@id @default(uuid())
	streak_count			Int 		@default(0)
	xp_points				Int 		@default(0)
	level					Int 		@default(0)
	reward_date				DateTime 	@default(now())

	user_id					String		@unique
	user 					User 		@relation(fields: [user_id], references: [id])
}

model DailyMatch {
	id 						String		@id @default(uuid())
	date 					DateTime	@unique @default(now())
	championId 				String
	champion 				Champion 	@relation(fields: [championId], references: [id])
}

model Country {
	id 						String @id @default(uuid())
	name 					String @unique
	continent				String
	flagUrl 				String
	countryId 				Int    @unique
	language 				String
	region 					String
	population 				Int
	currency 				String
	currencyName 			String

	dailyCountryMatches DailyCountryMatch[]
}

model DailyCountryMatch {
	id        				String   	@id @default(uuid())
	date      				DateTime 	@unique @default(now())
	countryId 				String
	country   				Country  	@relation(fields: [countryId], references: [id])
}
